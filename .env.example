# SkillHub Environment Variables
# Copy this file to .env and fill in real values before running the app.

# ----- Required -----

# PostgreSQL connection string (development).
# For local Postgres:
#   DATABASE_URL=postgresql://user:password@localhost:5432/skillhub
# For Supabase (Dashboard > Settings > Database > Connection string > URI):
#   DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/skillhub

# Express session signing secret (use a long random string in production)
SESSION_SECRET=replace-with-a-long-random-string

# ----- Optional: Production database -----
# If set, takes precedence over DATABASE_URL in production (NODE_ENV=production).
# Use the same Supabase URI format shown above.
PROD_DATABASE_URL=

# ----- Optional: Google OAuth -----
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Optional: GitHub OAuth -----
# Create an OAuth app at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----- Optional: Runtime -----
# Set to "production" when deploying
NODE_ENV=development

# Local port for the combined Express + Vite dev server
# If 5000 is already in use on your machine, set PORT=3005 (or another free port)
PORT=5000

# ----- CLI tool (shsc) -----
# Override the API base URL the CLI talks to (defaults to https://skillhub.space)
SKILLHUB_API=

# ----- Supabase -----
# Create tables by running supabase-schema.sql in the SQL Editor,
# then add the RPC functions from supabase-rpcs.sql.
# Find these values in Supabase Dashboard > Settings > API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# DATABASE_URL is still used for the session store (connect-pg-simple).
# Use the Supabase connection string from Dashboard > Settings > Database.

# ----- Notes -----
# OpenAI API key is NOT set as an env var.
# Each user provides their own key via the Settings > AI page (BYOK model),
# stored encrypted per-user in the database.
