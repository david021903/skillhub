{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillBook Skill Manifest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,62}[a-z0-9]$"
    },
    "display_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    },
    "license": {
      "type": "string"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "frameworks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "min_runtime": {
          "type": "string"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "linux",
              "windows",
              "macos"
            ]
          }
        }
      },
      "required": [
        "frameworks",
        "platforms"
      ]
    },
    "entrypoints": {
      "type": "object",
      "properties": {
        "skill_md": {
          "type": "string"
        },
        "runner": {
          "type": "string"
        },
        "tests": {
          "type": "string"
        }
      },
      "required": [
        "skill_md"
      ]
    },
    "permissions": {
      "type": "object",
      "properties": {
        "network": {
          "type": "boolean",
          "default": false
        },
        "filesystem": {
          "type": "boolean",
          "default": false
        },
        "browser": {
          "type": "boolean",
          "default": false
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "release": {
      "type": "object",
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sbom": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "name",
    "display_name",
    "version",
    "description",
    "license",
    "compatibility",
    "entrypoints"
  ]
}